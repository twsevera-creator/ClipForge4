{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "pip install --upgrade pip setuptools wheel",
        "pip install -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --timeout 600 --worker-class gthread --threads 4"
  }
}
